{
  "git": {
    "baseBranch": "main",
    "integrationBranch": "develop",
    "pushPolicy": "manual",
    "commitFormat": "conventional",
    "branchPatterns": {
      "feature": "feature/US-{N}-{short-title}",
      "fix": "fix/US-{N}-{short-title}",
      "release": "release/{version}"
    }
  },
  "pipeline": {
    "mode": "lean",
    "devPlanReview": false
  },
  "permissions": {
    "allowedTools": ["Bash", "Edit", "Write", "Read", "Glob", "Grep", "Agent"],
    "autoApprove": {
      "Bash": true,
      "Edit": true,
      "Write": true,
      "Agent": true
    }
  },
  "language": "es"
}
