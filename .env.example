# === Backend Environment Variables ===

# Database
DB_PASSWORD=postgres

# JWT Secrets (min 32 chars, generate random)
JWT_SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# Resend Email API
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=noreply@tuplataforma.com

# Email Mode
EMAIL_USE_FAKE=false

# CORS & URLs
CORS_ORIGIN=https://your-vercel-site.vercel.app
APP_BASE_URL=https://api.render.com/your-backend-url
APP_SITE_URL=https://your-vercel-site.vercel.app

# Environment
ASPNETCORE_ENVIRONMENT=Production

# === Frontend (Vercel) ===
NEXT_PUBLIC_API_URL=https://your-backend-url.com
